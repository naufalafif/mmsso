  echo "  mmsso thread <post-id>       Fetch the full thread containing a given post"
  echo "  mmsso dms                    List your direct message channels"
  echo "  mmsso dm <username>          Read messages from a DM channel"
  echo "  mmsso help                   Show this help"
  echo "  mmsso <any mmctl command>    Auto-refresh + passthrough to mmctl"
