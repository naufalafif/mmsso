# ── Main dispatch ────────────────────────────────────────────────────────────

main() {
  case "${1:-}" in
    setup)
      cmd_setup
      ;;
    status)
      cmd_status
      ;;
    refresh)
      cmd_refresh
      ;;
    search)
      shift
      cmd_search "$@"
      ;;
    thread)
      shift
      cmd_thread "$@"
      ;;
    dms)
      shift
      cmd_dms "$@"
      ;;
    dm)
      shift
      cmd_dm "$@"
      ;;
    help|--help|-h|"")
      cmd_help
      ;;
    *)
      # Passthrough to mmctl with auto-refresh
      load_config

      if [[ -z "${MM_URL:-}" ]]; then
        fail "Not configured yet."
        hint "Run: mmsso setup"
        exit 1
      fi

      local mmctl_path
      if ! mmctl_path=$(find_mmctl); then
        fail "mmctl is not installed."
        hint "Run: mmsso setup"
        exit 1
      fi

      # Auto-refresh (fully silent in passthrough mode)
      do_refresh false >/dev/null 2>&1 || {
        warn "Token refresh failed — trying with existing token."
      }

      exec "$mmctl_path" "$@"
      ;;
  esac
}

main "$@"
