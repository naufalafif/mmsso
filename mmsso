#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# mmsso — Mattermost CLI with auto-refreshing SSO tokens
#
# A drop-in wrapper around mmctl that automatically refreshes your session
# token from Chrome's cookie store. No passwords, no PATs, no manual steps.
#
# Usage:
#   mmsso setup                  First-time setup (interactive)
#   mmsso status                 Show auth status, token age, server info
#   mmsso refresh                Force-refresh the token from Chrome
#   mmsso <any mmctl command>    Auto-refresh + passthrough to mmctl
#
# Examples:
#   mmsso team list --json
#   mmsso post list myteam:general --json --show-ids -n 100
#   mmsso channel list myteam --json
#
# Config: ~/.config/mmsso/
# ─────────────────────────────────────────────────────────────────────────────
set -euo pipefail

# ── Config paths ─────────────────────────────────────────────────────────────
CONFIG_DIR="${HOME}/.config/mmsso"
CONFIG_FILE="${CONFIG_DIR}/config"
TOKEN_FILE="${CONFIG_DIR}/token"
MM_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOKEN_MAX_AGE_SECONDS=3600  # refresh if older than 1 hour

# ── Cookie reader discovery ──────────────────────────────────────────────────
# The compiled Swift binary — macOS Keychain permission scopes to it specifically.
find_cookie_reader() {
  local bin_name="cookie-reader"
  if [[ -x "${MM_SCRIPT_DIR}/${bin_name}" ]]; then
    echo "${MM_SCRIPT_DIR}/${bin_name}"
  elif command -v "$bin_name" >/dev/null 2>&1; then
    command -v "$bin_name"
  else
    echo ""
  fi
}
COOKIE_READER="$(find_cookie_reader)"

# ── Colors & formatting ─────────────────────────────────────────────────────
if [[ -t 1 ]]; then
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  YELLOW='\033[0;33m'
  BLUE='\033[0;34m'
  BOLD='\033[1m'
  DIM='\033[2m'
  RESET='\033[0m'
else
  RED='' GREEN='' YELLOW='' BLUE='' BOLD='' DIM='' RESET=''
fi

info()  { echo -e "${BLUE}▸${RESET} $*"; }
ok()    { echo -e "${GREEN}✓${RESET} $*"; }
warn()  { echo -e "${YELLOW}!${RESET} $*" >&2; }
fail()  { echo -e "${RED}✗${RESET} $*" >&2; }
hint()  { echo -e "  ${DIM}$*${RESET}" >&2; }

# ── REST API helpers ─────────────────────────────────────────────────────────
# Used by mmsso search / dms / dm — mmctl doesn't expose these endpoints, but
# the session token in ~/.config/mmsso/token authenticates fine against them.

api_get() {
  local path="$1"
  local token
  token="$(cat "$TOKEN_FILE" 2>/dev/null)" || return 1
  [[ -z "$token" ]] && return 1
  /usr/bin/curl -sf -H "Authorization: Bearer $token" "${MM_URL}${path}"
}

api_post_json() {
  # Reads JSON body from stdin
  local path="$1"
  local token
  token="$(cat "$TOKEN_FILE" 2>/dev/null)" || return 1
  [[ -z "$token" ]] && return 1
  /usr/bin/curl -sf -H "Authorization: Bearer $token" \
    -H "Content-Type: application/json" \
    -X POST --data-binary @- "${MM_URL}${path}"
}

resolve_team_id() {
  # Picks the first team the user is a member of. Good enough for single-team users.
  # If MM_AUTH_NAME matches a team, prefer that (future-proof for multi-team).
  api_get /api/v4/users/me/teams | python3 -c "
import json, sys, os
teams = json.load(sys.stdin)
if not teams:
    sys.exit(1)
pref = os.environ.get('MM_AUTH_NAME', '')
for t in teams:
    if t.get('name') == pref or t.get('display_name') == pref:
        print(t['id'])
        sys.exit(0)
print(teams[0]['id'])
" 2>/dev/null
}

# ── Helpers ──────────────────────────────────────────────────────────────────

find_mmctl() {
  if command -v mmctl >/dev/null 2>&1; then
    command -v mmctl
  elif [[ -x "${HOME}/bin/mmctl" ]]; then
    echo "${HOME}/bin/mmctl"
  else
    return 1
  fi
}

load_config() {
  MM_URL=""
  MM_AUTH_NAME=""
  if [[ -f "$CONFIG_FILE" ]]; then
    # Safe parsing: only read expected key=value lines, never source arbitrary code
    while IFS='=' read -r key value; do
      # Strip surrounding quotes from value
      value="${value%\"}"
      value="${value#\"}"
      case "$key" in
        MM_URL)       MM_URL="$value" ;;
        MM_AUTH_NAME) MM_AUTH_NAME="$value" ;;
      esac
    done < <(grep -E '^(MM_URL|MM_AUTH_NAME)=' "$CONFIG_FILE")
  fi
}

save_config() {
  mkdir -p "$CONFIG_DIR"
  chmod 700 "$CONFIG_DIR"
  cat > "$CONFIG_FILE" <<EOF
# mmsso configuration — generated by mmsso setup
MM_URL="${MM_URL}"
MM_AUTH_NAME="${MM_AUTH_NAME}"
EOF
  chmod 600 "$CONFIG_FILE"
}

token_age_seconds() {
  if [[ ! -f "$TOKEN_FILE" ]]; then
    echo "999999"
    return
  fi
  if [[ "$(uname -s)" == "Darwin" ]]; then
    echo $(( $(date +%s) - $(stat -f %m "$TOKEN_FILE") ))
  else
    echo $(( $(date +%s) - $(stat -c %Y "$TOKEN_FILE") ))
  fi
}

token_age_human() {
  local age=$1
  if (( age < 60 )); then
    echo "${age}s ago"
  elif (( age < 3600 )); then
    echo "$(( age / 60 ))m ago"
  elif (( age < 86400 )); then
    echo "$(( age / 3600 ))h ago"
  else
    echo "$(( age / 86400 ))d ago"
  fi
}

# ── Token refresh ────────────────────────────────────────────────────────────

show_no_session_error() {
  echo "" >&2
  fail "No active Mattermost session found in Chrome."
  echo "" >&2
  echo -e "  ${BOLD}To fix this:${RESET}" >&2
  echo -e "  1. Open ${BLUE}${MM_URL}${RESET} in Google Chrome" >&2
  echo -e "  2. Log in via SSO (if prompted)" >&2
  echo -e "  3. Wait for the Mattermost UI to fully load" >&2
  echo -e "  4. Come back here and run: ${BOLD}mmsso refresh${RESET}" >&2
  echo "" >&2
}

show_chrome_error() {
  echo "" >&2
  fail "Cannot read Chrome's cookie store."
  echo "" >&2
  echo -e "  ${BOLD}Common causes:${RESET}" >&2
  echo -e "  • Chrome is not installed" >&2
  echo -e "  • Chrome has never been opened (no cookie database yet)" >&2
  echo -e "  • macOS Keychain denied access — look for a system prompt" >&2
  echo -e "    asking to allow access to \"Chrome Safe Storage\"" >&2
  echo -e "    and click ${BOLD}Always Allow${RESET}" >&2
  echo "" >&2
}

refresh_via_binary() {
  local domain
  domain="$(echo "$MM_URL" | sed -E 's|https?://||' | sed 's|/.*||')"

  local token
  token=$("$COOKIE_READER" "$domain" "MMAUTHTOKEN" 2>/dev/null) || return 1

  if [[ -z "$token" ]]; then
    return 1
  fi

  mkdir -p "$CONFIG_DIR"
  chmod 700 "$CONFIG_DIR"
  printf '%s' "$token" > "$TOKEN_FILE"
  chmod 600 "$TOKEN_FILE"

  ok "Token refreshed (${#token} chars) → ${TOKEN_FILE}"
}

do_refresh() {
  local force="${1:-false}"

  load_config
  if [[ -z "$MM_URL" ]]; then
    fail "Not configured yet."
    hint "Run: mmsso setup"
    return 1
  fi

  # Static-token mode: no cookie-reader (e.g. Linux server with PAT) —
  # the token is assumed to be long-lived and refresh is a no-op.
  if [[ -z "$COOKIE_READER" || ! -x "$COOKIE_READER" ]]; then
    if [[ -s "$TOKEN_FILE" ]]; then
      return 0
    fi
    fail "No token and no cookie-reader."
    hint "Run: mmsso setup"
    return 1
  fi

  # Skip if token is fresh (unless forced)
  if [[ "$force" != "true" && -s "$TOKEN_FILE" ]]; then
    local age
    age=$(token_age_seconds)
    if (( age < TOKEN_MAX_AGE_SECONDS )); then
      return 0
    fi
  fi

  local domain
  domain="$(echo "$MM_URL" | sed -E 's|https?://||' | sed 's|/.*||')"

  local err
  err=$("$COOKIE_READER" "$domain" "MMAUTHTOKEN" 2>&1 1>/dev/null) || true

  if refresh_via_binary 2>/dev/null; then
    return 0
  fi

  if echo "$err" | grep -qi "not found in Chrome\|cookie not found"; then
    show_no_session_error
  elif echo "$err" | grep -qi "Keychain\|denied\|not found in Keychain"; then
    show_chrome_error
  else
    fail "Token refresh failed."
    echo "$err" | grep -i "ERROR" | sed 's/^/  /' >&2
  fi
  return 1
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_setup() {
  echo ""
  echo -e "${BOLD}mmsso setup${RESET} — configure Mattermost CLI with auto-refreshing SSO tokens"
  echo ""

  # 1. Check mmctl
  info "Checking for mmctl ..."
  local mmctl_path
  if mmctl_path=$(find_mmctl); then
    ok "Found mmctl at ${mmctl_path}"
    hint "$("$mmctl_path" version 2>/dev/null | head -1 || echo 'unknown version')"
  else
    fail "mmctl is not installed."
    echo ""
    echo -e "  ${BOLD}Install it:${RESET}"
    echo -e "  • Homebrew:  ${BOLD}brew install mmctl${RESET}"
    echo -e "  • Direct:    Download from ${BLUE}https://releases.mattermost.com/mmctl/\${VERSION}/\${PLATFORM}_\${ARCH}.tar${RESET}"
    echo -e "               Supported: darwin_arm64, darwin_amd64, linux_amd64, linux_arm64"
    echo -e "  • Note:      The old github.com/mattermost/mmctl repo is ${RED}archived${RESET}."
    echo ""
    echo -e "  After installing, run ${BOLD}mmsso setup${RESET} again."
    return 1
  fi

  # 2. Check cookie-reader (optional — desktop-only, not expected on Linux)
  COOKIE_READER="$(find_cookie_reader)"
  if [[ -n "$COOKIE_READER" ]]; then
    ok "Found cookie-reader at ${COOKIE_READER}"
    hint "Keychain permission scoped to this binary"
  else
    info "cookie-reader not installed — will use static-token mode"
    hint "macOS users can install auto-refresh via: brew install naufalafif/tap/mmsso"
  fi

  # 3. Check Chrome (only if using cookie-reader auto-refresh mode)
  if [[ -n "$COOKIE_READER" && "$(uname -s)" == "Darwin" ]]; then
    info "Checking for Chrome ..."
    local chrome_cookie_db="${HOME}/Library/Application Support/Google/Chrome/Default/Cookies"
    if [[ -f "$chrome_cookie_db" ]]; then
      ok "Chrome cookie database found."
    elif [[ -d "/Applications/Google Chrome.app" ]]; then
      warn "Chrome is installed but no cookie database found."
      hint "Open Chrome and browse to any site once, then re-run setup."
      return 1
    else
      fail "Google Chrome is not installed."
      hint "Download from https://www.google.com/chrome/ (or skip cookie-reader and use a PAT)"
      return 1
    fi
  fi

  # 4. Ask for server URL
  echo ""
  load_config
  local default_url="${MM_URL:-}"
  if [[ -n "$default_url" ]]; then
    read -rp "$(echo -e "${BLUE}▸${RESET}") Mattermost server URL [${default_url}]: " input_url
    MM_URL="${input_url:-$default_url}"
  else
    read -rp "$(echo -e "${BLUE}▸${RESET}") Mattermost server URL: " MM_URL
  fi

  if [[ -z "$MM_URL" ]]; then
    fail "Server URL is required."
    return 1
  fi
  # Normalize: strip trailing slash
  MM_URL="${MM_URL%/}"

  # 5. Auth name
  local default_name="${MM_AUTH_NAME:-work}"
  read -rp "$(echo -e "${BLUE}▸${RESET}") Auth name (nickname for this server) [${default_name}]: " input_name
  MM_AUTH_NAME="${input_name:-$default_name}"

  # 6. Save config
  save_config
  ok "Config saved to ${CONFIG_FILE}"

  # 7. Obtain token — cookie-reader (macOS desktop) OR paste a PAT (server/Linux)
  echo ""
  if [[ -n "$COOKIE_READER" && -x "$COOKIE_READER" ]]; then
    info "Reading Mattermost session from Chrome ..."
    hint "If macOS asks for Keychain access to \"Chrome Safe Storage\", click Always Allow."
    echo ""
    do_refresh true || {
      echo ""
      warn "Could not read token from Chrome. Make sure you're logged into Mattermost in Chrome."
      hint "After logging in, run: mmsso refresh"
      return 1
    }
  else
    info "Static-token mode (no cookie-reader — Linux server or Chrome not available)"
    echo ""
    echo -e "  Paste a Personal Access Token or bot token:"
    read -rsp "$(echo -e "${BLUE}▸${RESET}") Token: " pat_input
    echo ""
    pat_input="$(echo "$pat_input" | tr -d '[:space:]')"
    if [[ -z "$pat_input" ]]; then
      fail "Token is required."
      return 1
    fi
    mkdir -p "$CONFIG_DIR" && chmod 700 "$CONFIG_DIR"
    local fd
    exec {fd}>"$TOKEN_FILE"
    printf '%s' "$pat_input" >&${fd}
    exec {fd}>&-
    chmod 600 "$TOKEN_FILE"
    ok "Token saved (${#pat_input} chars) → ${TOKEN_FILE}"
  fi

  # 8. Set up mmctl auth
  info "Configuring mmctl auth ..."
  if "$mmctl_path" auth login "$MM_URL" \
      --name "$MM_AUTH_NAME" \
      --access-token-file "$TOKEN_FILE" 2>/dev/null; then
    ok "mmctl auth configured as \"${MM_AUTH_NAME}\""
  else
    warn "mmctl auth login had an issue — you may need to run it manually:"
    hint "$mmctl_path auth login $MM_URL --name $MM_AUTH_NAME --access-token-file $TOKEN_FILE"
  fi

  # 9. Verify
  echo ""
  info "Verifying connection ..."
  if "$mmctl_path" team list --suppress-warnings 2>/dev/null; then
    echo ""
    ok "Setup complete! You can now use ${BOLD}mmsso${RESET} as a drop-in replacement for mmctl."
    echo ""
    echo -e "  ${BOLD}Try it:${RESET}"
    echo -e "    mmsso team list --json"
    echo -e "    mmsso search \"deploy failed\" -n 10"
    echo -e "    mmsso dms"
    echo ""
  else
    warn "Connection test failed — token might be expired or invalid."
    if [[ -n "$COOKIE_READER" && -x "$COOKIE_READER" ]]; then
      hint "Open ${MM_URL} in Chrome, log in, and run: mmsso refresh"
    else
      hint "Check the PAT and re-run: mmsso setup"
    fi
  fi
}

cmd_status() {
  load_config

  echo ""
  echo -e "${BOLD}mmsso status${RESET}"
  echo ""

  # Server
  if [[ -n "${MM_URL:-}" ]]; then
    echo -e "  Server:     ${BLUE}${MM_URL}${RESET}"
    echo -e "  Auth name:  ${MM_AUTH_NAME:-not set}"
  else
    echo -e "  Server:     ${DIM}not configured${RESET}"
    hint "Run: mmsso setup"
    echo ""
    return
  fi

  # mmctl
  local mmctl_path
  if mmctl_path=$(find_mmctl); then
    local ver
    ver=$("$mmctl_path" version 2>/dev/null | grep "^Version:" | awk '{print $2}' | head -1 || echo "unknown")
    echo -e "  mmctl:      ${GREEN}${mmctl_path}${RESET} (v${ver})"
  else
    echo -e "  mmctl:      ${RED}not found${RESET}"
  fi

  # Token
  if [[ -s "$TOKEN_FILE" ]]; then
    local age
    age=$(token_age_seconds)
    local age_str
    age_str=$(token_age_human "$age")
    local token_len
    token_len=$(wc -c < "$TOKEN_FILE" | tr -d ' ')
    if (( age < TOKEN_MAX_AGE_SECONDS )); then
      echo -e "  Token:      ${GREEN}valid${RESET} (${token_len} chars, refreshed ${age_str})"
    else
      echo -e "  Token:      ${YELLOW}stale${RESET} (${token_len} chars, refreshed ${age_str})"
      hint "Will auto-refresh on next command, or run: mmsso refresh"
    fi
  else
    echo -e "  Token:      ${RED}missing${RESET}"
    hint "Run: mmsso refresh"
  fi

  # Cookie reader (auto-refresh) — optional on Linux/server setups using a PAT
  if [[ -n "$COOKIE_READER" && -x "$COOKIE_READER" ]]; then
    echo -e "  cookie-reader: ${GREEN}${COOKIE_READER}${RESET}"
    echo -e "  Mode:       ${GREEN}auto-refresh${RESET} (reads Chrome cookie)"
  else
    echo -e "  cookie-reader: ${DIM}not installed${RESET}"
    echo -e "  Mode:       ${GREEN}static token${RESET} (e.g. Personal Access Token)"
  fi

  # Live auth test
  if [[ -n "${mmctl_path:-}" && -s "$TOKEN_FILE" ]]; then
    if "$mmctl_path" auth current --suppress-warnings >/dev/null 2>&1; then
      echo -e "  Connection: ${GREEN}authenticated${RESET}"
    else
      echo -e "  Connection: ${RED}not authenticated${RESET}"
      hint "Token may be expired. Run: mmsso refresh"
    fi
  fi

  echo ""
}

cmd_refresh() {
  load_config
  if [[ -z "${MM_URL:-}" ]]; then
    fail "Not configured yet."
    hint "Run: mmsso setup"
    return 1
  fi
  if [[ -z "$COOKIE_READER" || ! -x "$COOKIE_READER" ]]; then
    warn "Static-token mode — no Chrome cookie to refresh."
    hint "If your token is expired, update it with: mmsso setup"
    return 0
  fi
  info "Refreshing token from Chrome ..."
  do_refresh true
}

# ── Extended commands (search, DMs) — use REST API directly ──────────────────
# mmctl doesn't expose these, but our session token authenticates fine.

_precheck() {
  load_config
  if [[ -z "${MM_URL:-}" ]]; then
    fail "Not configured yet."
    hint "Run: mmsso setup"
    return 1
  fi
  do_refresh false >/dev/null 2>&1 || true
  if [[ ! -s "$TOKEN_FILE" ]]; then
    fail "No token. Run: mmsso refresh"
    return 1
  fi
}

cmd_search() {
  if [[ $# -lt 1 || "$1" == "--help" || "$1" == "-h" ]]; then
    echo "Usage: mmsso search <terms> [-n LIMIT] [--json]"
    echo ""
    echo "  Full-text search across channels you have access to."
    echo "  Example: mmsso search \"ralph loop\" -n 10"
    return
  fi

  local terms="$1"; shift
  local json_out=false
  local limit=20

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) json_out=true; shift ;;
      -n) limit="$2"; shift 2 ;;
      *) warn "Unknown flag: $1"; shift ;;
    esac
  done

  _precheck || return 1

  local team_id
  team_id="$(MM_AUTH_NAME="$MM_AUTH_NAME" resolve_team_id)"
  if [[ -z "$team_id" ]]; then
    fail "Could not resolve team ID."
    return 1
  fi

  local payload
  payload="$(TERMS="$terms" python3 -c 'import os, json; print(json.dumps({"terms": os.environ["TERMS"], "is_or_search": False}))')"

  local response
  response="$(printf '%s' "$payload" | api_post_json "/api/v4/teams/${team_id}/posts/search")" || {
    fail "Search failed."
    return 1
  }

  if $json_out; then
    echo "$response"
  else
    echo "$response" | LIMIT="$limit" TOKEN_FILE="$TOKEN_FILE" MM_URL="$MM_URL" python3 -c '
import json, sys, os, urllib.request
from datetime import datetime

token = open(os.environ["TOKEN_FILE"]).read().strip()
base = os.environ["MM_URL"]

def api_get(path):
    req = urllib.request.Request(base + path, headers={
        "Authorization": "Bearer " + token,
        "User-Agent": "mmsso/1.0"
    })
    return json.loads(urllib.request.urlopen(req, timeout=10).read())

def api_post(path, body):
    req = urllib.request.Request(
        base + path,
        data=json.dumps(body).encode(),
        headers={
            "Authorization": "Bearer " + token,
            "Content-Type": "application/json",
            "User-Agent": "mmsso/1.0"
        }
    )
    return json.loads(urllib.request.urlopen(req, timeout=10).read())

d = json.load(sys.stdin)
order = d.get("order", [])
posts = d.get("posts", {})
total = len(order)
limit = int(os.environ.get("LIMIT", "20"))
shown_ids = order[:limit]

if total == 0:
    print("No results.")
    sys.exit(0)

# Resolve user_ids (batch) and channel_ids (individual)
user_ids = sorted({posts[pid]["user_id"] for pid in shown_ids if posts[pid].get("user_id")})
channel_ids = sorted({posts[pid]["channel_id"] for pid in shown_ids if posts[pid].get("channel_id")})

users = {}
if user_ids:
    try:
        for u in api_post("/api/v4/users/ids", user_ids):
            users[u["id"]] = u.get("username", u["id"][:8])
    except Exception:
        pass

channels = {}
for cid in channel_ids:
    try:
        c = api_get("/api/v4/channels/" + cid)
        channels[cid] = c.get("display_name") or c.get("name") or cid[:10]
    except Exception:
        channels[cid] = cid[:10]

suffix = "es" if total != 1 else ""
print("{} match{} (showing {}):".format(total, suffix, len(shown_ids)))
print()
for pid in shown_ids:
    p = posts[pid]
    ts = datetime.fromtimestamp(p["create_at"]/1000).strftime("%Y-%m-%d %H:%M")
    uname = users.get(p.get("user_id", ""), (p.get("user_id") or "")[:8])
    cname = channels.get(p.get("channel_id", ""), (p.get("channel_id") or "")[:10])
    msg = p.get("message", "").strip().split("\n")[0][:140]
    thread_marker = " [thread]" if p.get("reply_count", 0) > 0 else ""
    root_marker = " (reply)" if p.get("root_id") else ""
    print("[{}] @{} in ~{}{}{}".format(ts, uname, cname, thread_marker, root_marker))
    print("  post_id={} channel_id={}".format(pid, p.get("channel_id", "")))
    print("  {}".format(msg))
    print()
'
  fi
}

cmd_thread() {
  if [[ $# -lt 1 || "$1" == "--help" || "$1" == "-h" ]]; then
    echo "Usage: mmsso thread <post-id> [--json]"
    echo ""
    echo "  Fetch the full thread containing a given post."
    echo "  Example: mmsso thread okwomhfam7bfjr1ffwd9yjgfow"
    return
  fi

  local post_id="$1"; shift
  local json_out=false
  [[ "${1:-}" == "--json" ]] && json_out=true

  _precheck || return 1

  local response
  response="$(api_get "/api/v4/posts/${post_id}/thread")" || {
    fail "Failed to fetch thread (post may not exist or you lack access)."
    return 1
  }

  if $json_out; then
    echo "$response"
  else
    echo "$response" | TOKEN_FILE="$TOKEN_FILE" MM_URL="$MM_URL" python3 -c '
import json, sys, os, urllib.request
from datetime import datetime

token = open(os.environ["TOKEN_FILE"]).read().strip()
base = os.environ["MM_URL"]

def api_post(path, body):
    req = urllib.request.Request(
        base + path,
        data=json.dumps(body).encode(),
        headers={
            "Authorization": "Bearer " + token,
            "Content-Type": "application/json",
            "User-Agent": "mmsso/1.0"
        }
    )
    return json.loads(urllib.request.urlopen(req, timeout=10).read())

d = json.load(sys.stdin)
order = d.get("order", [])
posts = d.get("posts", {})
if not order:
    print("(empty thread)")
    sys.exit(0)

# Resolve usernames
user_ids = sorted({posts[pid]["user_id"] for pid in order if posts[pid].get("user_id")})
users = {}
if user_ids:
    try:
        for u in api_post("/api/v4/users/ids", user_ids):
            users[u["id"]] = u.get("username", u["id"][:8])
    except Exception:
        pass

# Order is chronological from API; print oldest first
sorted_ids = sorted(order, key=lambda p: posts[p]["create_at"])
for idx, pid in enumerate(sorted_ids):
    p = posts[pid]
    ts = datetime.fromtimestamp(p["create_at"]/1000).strftime("%Y-%m-%d %H:%M")
    uname = users.get(p.get("user_id", ""), (p.get("user_id") or "")[:8])
    prefix = "ROOT" if not p.get("root_id") else "  └─"
    msg = p.get("message", "").strip() or "(no text)"
    lines = msg.split("\n")
    print("{} [{}] @{}: {}".format(prefix, ts, uname, lines[0]))
    for line in lines[1:]:
        print("              {}".format(line))
    if idx == 0 and len(sorted_ids) > 1:
        print()
'
  fi
}

cmd_dms() {
  if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    echo "Usage: mmsso dms [--json]"
    echo ""
    echo "  List your direct message channels with counterpart usernames."
    return
  fi

  local json_out=false
  [[ "${1:-}" == "--json" ]] && json_out=true

  _precheck || return 1

  local team_id
  team_id="$(MM_AUTH_NAME="$MM_AUTH_NAME" resolve_team_id)" || { fail "No team."; return 1; }

  local channels
  channels="$(api_get "/api/v4/users/me/teams/${team_id}/channels")" || {
    fail "Failed to list channels."
    return 1
  }

  local me_id
  me_id="$(api_get /api/v4/users/me | python3 -c 'import json, sys; print(json.load(sys.stdin)["id"])')"

  # Extract DM channels (type=D) with the other participant's user_id
  local dm_list
  dm_list="$(echo "$channels" | ME="$me_id" python3 -c '
import json, sys, os
me = os.environ["ME"]
data = json.load(sys.stdin)
dms = []
for c in data:
    if c.get("type") != "D":
        continue
    parts = c["name"].split("__")
    other = parts[0] if parts[0] != me else (parts[1] if len(parts) > 1 else me)
    dms.append({"id": c["id"], "other_id": other, "last": c.get("last_post_at", 0)})
dms.sort(key=lambda x: x["last"], reverse=True)
for dm in dms:
    print("{}\t{}\t{}".format(dm["id"], dm["other_id"], dm["last"]))
')"

  if [[ -z "$dm_list" ]]; then
    echo "No DMs."
    return
  fi

  if $json_out; then
    # Resolve other_ids to usernames for richer JSON
    local resolved="["
    local first=true
    while IFS=$'\t' read -r ch_id other_id last; do
      local uname
      uname="$(api_get "/api/v4/users/${other_id}" 2>/dev/null | python3 -c 'import json,sys; print(json.load(sys.stdin).get("username",""))' 2>/dev/null)"
      $first || resolved="${resolved},"
      first=false
      resolved="${resolved}{\"channel_id\":\"${ch_id}\",\"username\":\"${uname}\",\"user_id\":\"${other_id}\",\"last_post_at\":${last:-0}}"
    done <<< "$dm_list"
    resolved="${resolved}]"
    echo "$resolved" | python3 -m json.tool
  else
    printf "%-28s %-30s %s\n" "CHANNEL_ID" "USERNAME" "LAST_POST"
    while IFS=$'\t' read -r ch_id other_id last; do
      local uname
      uname="$(api_get "/api/v4/users/${other_id}" 2>/dev/null | python3 -c 'import json,sys; print(json.load(sys.stdin).get("username","?"))' 2>/dev/null || echo "?")"
      local last_str="-"
      if [[ "$last" != "0" && -n "$last" ]]; then
        last_str="$(python3 -c "from datetime import datetime; print(datetime.fromtimestamp($last/1000).strftime('%Y-%m-%d %H:%M'))")"
      fi
      printf "%-28s %-30s %s\n" "$ch_id" "@$uname" "$last_str"
    done <<< "$dm_list"
  fi
}

cmd_dm() {
  if [[ $# -lt 1 || "$1" == "--help" || "$1" == "-h" ]]; then
    echo "Usage: mmsso dm <username> [-n LIMIT] [--json] [--show-ids]"
    echo ""
    echo "  Read messages from a direct message channel."
    echo "  Example: mmsso dm john.doe -n 50"
    return
  fi

  local username="$1"; shift
  local json_out=false
  local limit=30
  local show_ids=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) json_out=true; shift ;;
      --show-ids) show_ids=true; shift ;;
      -n) limit="$2"; shift 2 ;;
      *) warn "Unknown flag: $1"; shift ;;
    esac
  done

  _precheck || return 1

  # Resolve usernames → user_ids
  local me_id target_id
  me_id="$(api_get /api/v4/users/me | python3 -c 'import json,sys; print(json.load(sys.stdin)["id"])')" || {
    fail "Failed to resolve your user ID."
    return 1
  }

  target_id="$(api_get "/api/v4/users/username/${username}" | python3 -c 'import json,sys; print(json.load(sys.stdin)["id"])' 2>/dev/null)" || true
  if [[ -z "$target_id" ]]; then
    fail "User not found: ${username}"
    return 1
  fi

  # Get-or-create DM channel
  local dm_channel
  dm_channel="$(printf '["%s","%s"]' "$me_id" "$target_id" | api_post_json /api/v4/channels/direct)" || {
    fail "Failed to open DM channel with @${username}."
    return 1
  }

  local dm_id
  dm_id="$(echo "$dm_channel" | python3 -c 'import json,sys; print(json.load(sys.stdin)["id"])')"

  # Fetch posts
  local posts
  posts="$(api_get "/api/v4/channels/${dm_id}/posts?per_page=${limit}")" || {
    fail "Failed to read DM messages."
    return 1
  }

  if $json_out; then
    echo "$posts"
  else
    ME="$me_id" OTHER_NAME="$username" SHOW_IDS="$show_ids" echo "$posts" | \
      ME="$me_id" OTHER_NAME="$username" SHOW_IDS="$show_ids" python3 -c '
import json, sys, os
from datetime import datetime
d = json.load(sys.stdin)
order = d.get("order", [])
posts = d.get("posts", {})
me = os.environ["ME"]
other = os.environ["OTHER_NAME"]
show_ids = os.environ.get("SHOW_IDS", "false") == "true"
if not order:
    print("(no messages)")
    sys.exit(0)
# Posts come newest-first; flip for chronological display
for pid in reversed(order):
    p = posts[pid]
    ts = datetime.fromtimestamp(p["create_at"]/1000).strftime("%Y-%m-%d %H:%M")
    who = "me" if p["user_id"] == me else other
    msg = p.get("message", "").strip()
    id_str = f" [{pid}]" if show_ids else ""
    if not msg:
        msg = "(no text)"
    # Multi-line messages: indent continuation
    lines = msg.split("\n")
    print(f"[{ts}] @{who}{id_str}: {lines[0]}")
    for line in lines[1:]:
        print(f"                {line}")
'
  fi
}

