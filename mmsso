  echo -e "${BOLD}COMMANDS${RESET}"
  echo "  mmsso setup                  First-time setup (interactive)"
  echo "  mmsso status                 Show auth status, token age, server info"
  echo "  mmsso refresh                Force-refresh the token from Chrome"
